# ============================================
# Project Configuration
# ============================================

# Input SoapUI project file (relative to project root)
INPUT_PROJECT_FILE=input/small_soapui_project.xml

# Available sample projects:
# - input/small_soapui_project.xml
# - input/Google-Maps-soapui-project.xml
# - input/Project-1-soapui-project.xml
# Or add your own: input/your-project.xml

# ============================================
# LLM Provider Configuration
# ============================================

# Choose one: 'openai', 'anthropic', 'ollama', 'groq', 'azure'
LLM_PROVIDER=ollama

# ============================================
# Cloud Provider Settings (OpenAI, Anthropic, Groq, Azure)
# ============================================

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Groq Configuration
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=your-azure-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ============================================
# Local Model Settings (Ollama)
# ============================================

OLLAMA_MODEL=mistral:latest
OLLAMA_BASE_URL=http://127.0.0.1:11434

# ============================================
# Generation Parameters (applies to all providers)
# ============================================

LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000
LLM_TIMEOUT=600
